# Percolator API Configuration
NODE_ENV=development

# Server
API_PORT=4000
API_VERSION=v1
# Production: set to exact origin(s) only — no wildcards.
# e.g. CORS_ORIGINS=https://percolatorlaunch.com
CORS_ORIGINS=http://localhost:3000
TRUSTED_PROXY_DEPTH=1

# Authentication
API_AUTH_KEY=

# WebSocket
MAX_WS_CONNECTIONS=100
WS_AUTH_REQUIRED=false
WS_AUTH_SECRET=

# Solana
# The shared library reads RPC_URL (not SOLANA_RPC_URL).
# For mainnet: use a paid RPC provider (Helius, Alchemy, etc.) — the public
# endpoint rate-limits aggressively and is unsuitable for production.
RPC_URL=https://api.mainnet-beta.solana.com

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Upstash Redis — rate limiting (required for multi-replica / production)
# Create a free database at https://console.upstash.com/
# When unset, falls back to in-memory rate limiting (single-replica only).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Helius webhook signature verification
# Must be a 32-byte (64-char) hex string. Rotate before mainnet.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HELIUS_WEBHOOK_SECRET=

# Monitoring
SENTRY_DSN=
DISCORD_ALERT_WEBHOOK=
